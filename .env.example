# OpenClaw 基础配置模板

# --- 飞书 (Feishu) 配置 ---
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_BOT_NAME=OpenClawBot

# --- 飞书多维表格 (Base) ---
FEISHU_BITABLE_APP_TOKEN=your_bitable_token
FEISHU_TABLE_ID_CONTENT_LIBRARY=table_id_1
FEISHU_TABLE_ID_SMART_CONTENT=table_id_2

# --- AI (LLM) 配置 ---
OPENAI_API_KEY=sk-xxxx
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4-turbo

# --- 公众号推送配置 ---
MP_APP_ID=xxx
MP_APP_SECRET=xxx
